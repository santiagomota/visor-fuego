    dplyr,
    fs,
    ggplot2,
    sf,
    knitr,
    giscoR,
    glue,
    htmltools,
    htmlwidgets,
    httr2,
    jsonlite,
    leaflet,
    png,
    purrr,
    readr,
    stringr,
    terra,
    tibble,
    tidyr
