# visor-fuego v0.6.9
# Copiar este fichero como .Renviron en la raíz del proyecto.
# No incluir .Renviron en Git si contiene claves reales.

# -----------------------------------------------------------------------------
# AEMET
# -----------------------------------------------------------------------------
# El proveedor classic descarga los GeoTIFF SIG y no necesita AEMET_API_KEY.
AEMET_PROVIDER=classic
AEMET_API_KEY=

# Estas variables se usan principalmente con AEMET_PROVIDER=opendata.
# En classic, el paquete incluye Península/Baleares y Canarias, D00-D07.
AEMET_AREAS=p,c
AEMET_FORECAST_DAYS=1,2,3,4,5,6,7
AEMET_PRODUCTS=previsto

AEMET_REQUIRE_GEOTIFF=true
AEMET_ALLOW_PNG_OVERLAY=false
AEMET_LEAFLET_PROJECTION=3857
AEMET_BOUNDS_NUDGE_LON=0
AEMET_BOUNDS_NUDGE_LAT=0

# D00 corresponde a Día 1 y a la fecha indicada en el nombre del fichero.
AEMET_CLASSIC_VALID_START_OFFSET_DAYS=0
AEMET_CLASSIC_KEEP_LATEST_ISSUE_ONLY=true
AEMET_CLASSIC_CLEAN_RAW_BEFORE_INSTALL=true
AEMET_INCLUDE_ORPHAN_RAW=false
AEMET_CLEAN_WEB_ASSETS=true

# -----------------------------------------------------------------------------
# NASA FIRMS
# -----------------------------------------------------------------------------
# Solicita una MAP_KEY gratuita en FIRMS. Si se deja vacía, la capa estará vacía.
FIRMS_MAP_KEY=
FIRMS_SOURCES=VIIRS_SNPP_NRT,VIIRS_NOAA20_NRT
FIRMS_DAYS=2
FIRMS_BBOX=-19,27,5,44.6

# -----------------------------------------------------------------------------
# Alertas e histórico
# -----------------------------------------------------------------------------
ALERT_CLUSTER_KM=12
ALERT_MAX_AGE_HOURS=48

HISTORY_MODE=daily_latest
HISTORY_KEEP_DAYS=90

# -----------------------------------------------------------------------------
# EFFIS FWI clásico
# -----------------------------------------------------------------------------
# Desactivado: el visor utiliza EFFIS Burnt Areas.
EFFIS_ENABLE=false
EFFIS_RENDER_MODE=disabled

# -----------------------------------------------------------------------------
# EFFIS Burnt Areas
# -----------------------------------------------------------------------------
EFFIS_BA_ENABLE=true
EFFIS_BA_URL=https://maps.effis.emergency.copernicus.eu/effis?outputformat=SHAPEZIP&request=getfeature&service=WFS&typename=ms:modis.ba.poly&version=1.1.0
EFFIS_BA_BBOX=-19,27,5,44.6
EFFIS_BA_MAX_DAYS=90
EFFIS_BA_MIN_AREA_HA=5
EFFIS_BA_SIMPLIFY_M=100
EFFIS_BA_TIMEOUT_SECONDS=900
EFFIS_BA_RETRIES=2
EFFIS_BA_OPTIONAL=true

# -----------------------------------------------------------------------------
# Límites administrativos
# -----------------------------------------------------------------------------
# Solo fuerza una nueva descarga cuando se cambia a true.
UPDATE_ADMIN_BOUNDARIES=false
