# AEMET
# classic usa la descarga SIG clásica /es/api-eltiempo/incendios/download.
# Devuelve GeoTIFFs georreferenciados y NO requiere AEMET_API_KEY.
# opendata mantiene el método anterior, útil solo para diagnóstico/fallback.
AEMET_PROVIDER=classic
AEMET_ALLOW_PNG_OVERLAY=false

# Conversión AEMET para Leaflet.
# 3857 reproyecta el GeoTIFF a Web Mercator antes de generar el PNG,
# que suele alinear mejor con Leaflet que estirar un PNG en EPSG:4326.
AEMET_LEAFLET_PROJECTION=3857
# Ajuste manual residual en grados. Déjalo a 0 salvo que valides un desplazamiento sistemático.
AEMET_BOUNDS_NUDGE_LON=0
AEMET_BOUNDS_NUDGE_LAT=0

# AEMET OpenData, solo necesario si AEMET_PROVIDER=opendata
AEMET_API_KEY=pon_aqui_tu_api_key_de_aemet
AEMET_AREAS=p,b,c
AEMET_FORECAST_DAYS=1,2,3,4,5,6,7
AEMET_PRODUCTS=previsto,estimado

# NASA FIRMS. Solicita una MAP_KEY gratuita en FIRMS.
# Si se deja vacío, el visor se renderiza sin focos FIRMS.
FIRMS_MAP_KEY=
FIRMS_SOURCES=VIIRS_SNPP_NRT,VIIRS_NOAA20_NRT
FIRMS_DAYS=2
FIRMS_BBOX=-19,27,5,44.6
# Opcional: YYYY-MM-DD. Si está vacío, FIRMS devuelve los datos más recientes.
FIRMS_DATE=

# EFFIS/Copernicus WMS
EFFIS_ENABLE=true
EFFIS_WMS_BASE=https://maps.effis.emergency.copernicus.eu/effis
EFFIS_WMS_LAYERS=ecmwf007.fwi
EFFIS_WMS_LABELS=EFFIS - FWI
# Opcional: YYYY-MM-DD. Si está vacío, se usa Sys.Date() al renderizar.
EFFIS_DATE=

# Límites administrativos Eurostat/GISCO NUTS
ADMIN_ENABLE=true
ADMIN_NUTS_YEAR=2021
ADMIN_RESOLUTION=10

# Alertas operativas FIRMS
ALERT_CLUSTER_KM=12
ALERT_MAX_AGE_HOURS=48

# Histórico temporal
# daily_latest conserva solo la última ejecución de cada día; append_runs conserva todas.
HISTORY_MODE=daily_latest
HISTORY_KEEP_DAYS=90
